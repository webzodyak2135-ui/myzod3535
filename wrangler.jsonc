{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "myzod3535",
  "compatibility_date": "2024-09-23",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "binding": "ASSETS",
    "directory": ".open-next/assets"
  },
  "observability": {
    "enabled": true
  },
  "main": ".open-next/worker.js",
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "myzod3535"
    }
  ]
}
